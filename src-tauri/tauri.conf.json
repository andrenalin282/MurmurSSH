{
  "productName": "MurmurSSH",
  "version": "1.4.1",
  "identifier": "de.kai-schultka.murmurssh",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MurmurSSH - Opensource SSH and SFTP client",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "publisher": "Kai André Schultka",
    "copyright": "© 2026 Kai André Schultka",
    "category": "Developer Tool",
    "shortDescription": "Minimal local-first SSH and SFTP client for Linux",
    "longDescription": "A minimal, local-first SSH and SFTP client for Linux. No cloud, no telemetry, no tracking — your data stays on your machine or in your own storage.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    }
  }
}
